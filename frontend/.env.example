# Backend URL (set this in Vercel → Project Settings → Environment Variables)
VITE_API_URL=https://your-backend-name.onrender.com

# PostHog analytics key (set this in Vercel → Project Settings → Environment Variables)
# Find it in PostHog → Project Settings → Project API Key
# If omitted, analytics are silently disabled — the app still works.
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
